#!/bin/sh

# Checks out an existing branch of the current repository,
# in a sibling directory named REPONAME-branch-BRANCHNAME/.
#
# Usage:
#   git-checkout-branch BRANCHNAME

# SCRIPT_DIR="$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd -P)"
SCRIPT_NAME="$(basename -- "$0")"

if [ "$#" -ne 1 ]; then
  echo "Usage: ${SCRIPT_NAME} BRANCHNAME" >&2
  exit 1
fi

STARTDIR="${PWD}"
trap 'cd "${STARTDIR}" || true' EXIT

if ! cd "$(git rev-parse --show-toplevel 2> /dev/null)"; then
  echo "${SCRIPT_NAME}: Cannot determine top-level directory of git repository" >&2
  git rev-parse --show-toplevel >&2
  exit 1
fi

REPO=$(basename "$(pwd)")
BRANCHNAME="$1"
BRANCHNOSLASH=$(echo "${BRANCHNAME}" | sed -e "s:/:-:g")
BRANCHDIR=$(realpath "../${REPO%%-branch-*}-branch-${BRANCHNOSLASH}")
BRANCH_TMPDIR="${BRANCHDIR}-TMP"

git pull -q > /dev/null 2>&1 || true

if ! git ls-remote --exit-code origin "${BRANCHNAME}" > /dev/null 2>&1; then
  echo "${SCRIPT_NAME}: ERROR: branch ${BRANCHNAME} does not exist." >&2
  exit 1
fi

if [ -e "${BRANCHDIR}" ]; then
  echo "${SCRIPT_NAME}: ERROR: directory exists: ${BRANCHDIR}" >&2
  exit 1
fi
if [ -e "${BRANCH_TMPDIR}" ]; then
  echo "${SCRIPT_NAME}: ERROR: directory exists: ${BRANCH_TMPDIR}" >&2
  exit 1
fi

if ! \cp -Rp . "${BRANCH_TMPDIR}"; then
  echo "${SCRIPT_NAME}: ERROR: cannot copy $(pwd) to ${BRANCH_TMPDIR}" >&2
  exit 1
fi
if ! (cd "${BRANCH_TMPDIR}" && git checkout "${BRANCHNAME}" -q); then
  echo "${SCRIPT_NAME}: ERROR in: (cd \"${BRANCH_TMPDIR}\" && git checkout \"${BRANCHNAME}\" -q)" >&2
  exit 1
fi

if ! mv "${BRANCH_TMPDIR}" "${BRANCHDIR}"; then
  echo "${SCRIPT_NAME}: ERROR in: mv \"${BRANCH_TMPDIR}\" \"${BRANCHDIR}\"" >&2
  exit 1
fi

echo "Success: checked out to ${BRANCHDIR}"
